{
  "name": "mv_hofki",
  "initializeCommand": "bash .devcontainer/initialize.sh",
  "build": {
    "dockerfile": "Dockerfile",
    "context": "..",
    "args": {
      "TZ": "${localEnv:TZ:Europe/Berlin}"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "Vue.volar",
        "anthropic.claude-code",
        "eamodio.gitlens",
        "dbaeumer.vscode-eslint"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  },
  "postCreateCommand": "bash ${containerWorkspaceFolder}/.devcontainer/post-create.sh",
  "postStartCommand": "bash ${containerWorkspaceFolder}/.devcontainer/post-start.sh",
  "mounts": [
    "source=${localWorkspaceFolderBasename}-bashhistory,target=/commandhistory,type=volume",
    "source=${localWorkspaceFolderBasename}-claude-config,target=/home/vscode/.claude,type=volume"
  ],
  "containerEnv": {
    "CLAUDE_CONFIG_DIR": "/home/vscode/.claude"
  },
  "runArgs": ["-p", "8000"],
  "forwardPorts": [8000],
  "portsAttributes": {
    "8000": {
      "label": "mv_hofki API + Frontend",
      "onAutoForward": "notify",
      "protocol": "http"
    }
  },
  "remoteUser": "vscode"
}
