{
  "name": "mv_hofki",
  "initializeCommand": "bash .devcontainer/initialize.sh",
  "dockerComposeFile": "docker-compose.yml",
  "service": "devcontainer",
  "workspaceFolder": "/workspaces/mv_hofki",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "Vue.volar",
        "anthropic.claude-code",
        "eamodio.gitlens",
        "dbaeumer.vscode-eslint"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  },
  "postCreateCommand": "bash ${containerWorkspaceFolder}/.devcontainer/post-create.sh",
  "postStartCommand": "bash ${containerWorkspaceFolder}/.devcontainer/post-start.sh",
  "containerEnv": {
    "CLAUDE_CONFIG_DIR": "/home/vscode/.claude"
  },
  "forwardPorts": [8000, 7681],
  "portsAttributes": {
    "8000": {
      "label": "mv_hofki API + Frontend",
      "onAutoForward": "notify",
      "protocol": "http"
    },
    "7681": {
      "label": "Web Terminal (ttyd)",
      "onAutoForward": "notify",
      "protocol": "http"
    }
  },
  "remoteUser": "vscode"
}
